class Solution {
public:
    int subarraysDivByK(vector<int>& nums, int k) {
        unordered_map<int,int> m;

        int prefixSum = 0;
        int totalSum  = 0;

        m[0] = 1;  

        for(int i = 0; i < nums.size(); i++){
            prefixSum += nums[i];

            int rem = prefixSum % k;

            if(rem < 0){
                rem += k;   // handle negative remainder
            }

            if(m.count(rem)){
                totalSum += m[rem];
            }

            m[rem]++;  // frequency update
        }

        return totalSum;
    }
};

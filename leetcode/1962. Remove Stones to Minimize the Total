class Solution {
public:
    int minStoneSum(vector<int>& piles, int k) {
        int sum = 0; 
        int n = piles.size();
        priority_queue<int>pq;
        for(int i = 0; i<n;i++){
            pq.push(piles[i]);
            sum+= piles[i];
        }
        for(int i =1 ; i<=k;i++){
            int maxele= pq.top();
            pq.pop();
            int remove = maxele/2;
            sum -= remove;
            maxele-= remove;
            pq.push(maxele);

        }
        return sum;
        
    }
};





